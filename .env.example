# ── Django ────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=*

# ── CORS ──────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=topmaster
POSTGRES_USER=topmaster
POSTGRES_PASSWORD=topmaster
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis (separate logical DBs for channels/celery/cache) ────────
REDIS_URL=redis://redis:6379/0
CHANNELS_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CACHE_REDIS_URL=redis://redis:6379/3

# ── JWT ───────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=14

# ── MinIO / S3 ────────────────────────────────────────────────────
USE_S3=true
MINIO_ROOT_USER=topmaster
MINIO_ROOT_PASSWORD=topmaster-secret
MINIO_BUCKET=topmaster-media
MINIO_ENDPOINT_URL=http://minio:9000
# Browser-facing base for media URLs (path-style → MUST include the bucket).
# In production point this at your CDN/public S3 host + bucket.
MINIO_PUBLIC_DOMAIN=localhost:9000/topmaster-media
MINIO_URL_PROTOCOL=http:
MINIO_QUERYSTRING_AUTH=false

# ── Email (transactional) ─────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=mailpit
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=TopMaster <no-reply@topmaster.uz>
# Front-end page the password-reset email links to (?uid=&token= appended).
FRONTEND_PASSWORD_RESET_URL=https://topmaster.uz/reset-password

# ── Firebase / FCM (optional) ─────────────────────────────────────
# Mount a service-account JSON and point to it; leave blank to disable push.
FIREBASE_CREDENTIALS_FILE=
