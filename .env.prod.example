# ─────────────────────────────────────────────────────────────────
# TopMaster — PRODUCTION environment template.
# Copy to `.env` on the server and fill in real secrets:
#   cp .env.prod.example .env  &&  nano .env
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER commit the real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
SECRET_KEY=CHANGE_ME_generate_a_64_char_random_string
# localhost/127.0.0.1 are required for the container's internal healthcheck
# (curl http://localhost:8000/health/). External traffic always arrives via
# Nginx with Host: topmaster.ismatov.uz.
ALLOWED_HOSTS=topmaster.ismatov.uz,localhost,127.0.0.1

# ── CORS / CSRF (frontend origin) ─────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://topmaster.ismatov.uz
CSRF_TRUSTED_ORIGINS=https://topmaster.ismatov.uz

# ── TLS / proxy ───────────────────────────────────────────────────
# Nginx terminates TLS and forwards X-Forwarded-Proto; keep redirect on.
SECURE_SSL_REDIRECT=True

# ── Database (Docker postgres service) ────────────────────────────
POSTGRES_DB=topmaster
POSTGRES_USER=topmaster
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis (Docker redis service) ──────────────────────────────────
REDIS_URL=redis://redis:6379/0
CHANNELS_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CACHE_REDIS_URL=redis://redis:6379/3

# ── File storage (MinIO, served via Nginx at /<bucket>/) ──────────
USE_S3=True
MINIO_ROOT_USER=topmaster
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_BUCKET=topmaster-media
MINIO_ENDPOINT_URL=http://minio:9000
# Browser-facing media base: domain + bucket (Nginx proxies this path to MinIO).
MINIO_PUBLIC_DOMAIN=topmaster.ismatov.uz/topmaster-media
MINIO_URL_PROTOCOL=https:
MINIO_REGION=us-east-1
# Public-read bucket → clean, unsigned media URLs.
MINIO_QUERYSTRING_AUTH=False

# ── Web server ────────────────────────────────────────────────────
GUNICORN_WORKERS=3

# ── Email (optional) ──────────────────────────────────────────────
# Console backend just logs emails. For real password-reset emails set SMTP:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=TopMaster <no-reply@topmaster.ismatov.uz>
FRONTEND_PASSWORD_RESET_URL=https://topmaster.ismatov.uz/reset-password

# ── JWT lifetimes (optional overrides) ────────────────────────────
# JWT_ACCESS_MINUTES=60
# JWT_REFRESH_DAYS=14

# ── Firebase / FCM (optional) ─────────────────────────────────────
# Mount the JSON into the container and point to it; blank = push disabled.
FIREBASE_CREDENTIALS_FILE=

# ── HSTS (optional, prod.py reads these) ──────────────────────────
SECURE_HSTS_SECONDS=31536000
